<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title and title != "Cocreiamo" %}{{ title }} | Cocreiamo{% else %}Cocreiamo — Software that fits your industry{% endif %}</title>
    <meta name="description" content="{{ description or 'Cocreiamo builds and manages vertical software for Italian companies.' }}" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" href="/assets/fonts/poppins-900-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/poppins-700-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/assets/css/site.css?v={{ cssHash }}" />
  </head>
  <body>

    <header class="site-header">
      <a href="/" class="site-logo">COCREIAMO</a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/#solutions">Solutions</a>
        <a href="/about/">About</a>
        <a href="mailto:info@cocreiamo.com" class="nav-cta">Get in touch</a>
      </nav>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">

        <div class="site-footer__left">
          <p class="site-footer__copy">
            &copy; <span id="year">2026</span> Cocreiamo.<br>
            All rights reserved.
          </p>
          <hr class="site-footer__rule" />
          <div class="site-footer__social">
            <a href="https://youtube.com/@cocreiamotechnologies" class="social-pill" rel="noopener">YouTube</a>
            <a href="https://x.com/cocreaimo" class="social-pill" rel="noopener">X</a>
            <a href="https://linkedin.com/company/cocreiamo-technologies" class="social-pill" rel="noopener">LinkedIn</a>
            <a href="https://github.com/cocreiamo" class="social-pill" rel="noopener">GitHub</a>
          </div>
        </div>

        <nav class="site-footer__nav" aria-label="Footer navigation">

          <div class="footer-col">
            <p class="footer-col__head">Solutions</p>
            <a href="/#solutions">Legacy Modernization</a>
            <a href="/#solutions">Vertical Software</a>
            <a href="/#solutions">AI &amp; Data</a>
            <a href="/#solutions">Managed Services</a>
          </div>

          <div class="footer-col">
            <p class="footer-col__head">Company</p>
            <a href="/about/">About</a>
            <a href="mailto:info@cocreiamo.com">Contact</a>
          </div>

          <div class="footer-col">
            <p class="footer-col__head">Legal</p>
            <a href="/privacy-policy/">Privacy Policy</a>
            <a href="/cookie-policy/">Cookie Policy</a>
            <a href="/accessibility/">Accessibility</a>
          </div>

        </nav>

      </div>
    </footer>

    <script src="/assets/js/year.js"></script>
  </body>
</html>
